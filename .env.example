# 数据源配置：二选一，优先读取 BINDING_DATA_FILE。
BINDING_DATA_FILE=./data/binding-sample.json
# BINDING_DATA_URL=https://example.com/api/bindings
# BINDING_DATA_METHOD=GET
# BINDING_DATA_BODY=

# 如果数据源需要 MG CLI 登录，将 BINDING_DATA_LOGIN 改为 mg。
# 可选值：none / mg
BINDING_DATA_LOGIN=none
MG_CENTER_BASE_URL=https://mg-cli.meimeifa.com
MG_CENTER_ACCOUNT=
MG_CENTER_PASSWORD=
MG_LOGIN_TOKEN_FIELD=token
# 可选值：authorization-bearer / mmf-token / token / none
BINDING_DATA_AUTH_HEADER=authorization-bearer

# JSON 提取配置：直接统计列表，或读取已汇总字段。
BINDING_LIST_PATH=data.list
BINDING_PHONE_FIELD=phone,mobile,handset,tel
BINDING_DATE_FIELD=created_at
PARTNER_NAME_FIELD=retail_store_name
PARTNER_ID_FIELD=retail_store_id
TOP_PARTNER_LIMIT=20
# TOTAL_BINDINGS_PATH=data.total
# PHONE_OBTAINED_PATH=data.withPhone
# PHONE_MISSING_PATH=data.withoutPhone

# 推送字段展示名，可以按后续口径调整。
REPORT_TITLE=恒奕美源绑定数据播报
REPORT_FIELDS=totalBindings:总绑定数,phoneObtained:已获手机号,phoneMissing:未获取手机号

# 私域宝推送配置。真实值只放本地 .env，不提交。
MG_SALON_ACCOUNT=
MG_SALON_PASSWORD=
MG_SYB_HANDSET=
MG_SYB_ROBOT_ID=
MG_SYB_SENDER_IDS=
# 兼容单好友配置；如果 MG_SYB_SENDER_IDS 已配置，会优先使用 MG_SYB_SENDER_IDS。
# MG_SYB_SENDER_ID=
# 群推送时使用 MG_SYB_GROUP_ID，并留空 MG_SYB_SENDER_IDS / MG_SYB_SENDER_ID。
# MG_SYB_GROUP_ID=

# 是否在发送前刷新 salonLogin / salonSyb 本地缓存。
SYB_REFRESH_CACHE=true
