# 数据源配置：二选一，优先读取 BINDING_DATA_FILE。
BINDING_DATA_FILE=./data/binding-sample.json
# BINDING_DATA_URL=https://example.com/api/bindings
# BINDING_DATA_METHOD=GET
# BINDING_DATA_BODY=

# 如果数据源需要服务端登录拿 token，可按接口类型配置。
# 可选值：none / lite / mg
# lite：使用 MG_SALON_ACCOUNT / MG_SALON_PASSWORD 登录 lite 后台，并把 token 写入 query。
# mg：使用 MG_CENTER_ACCOUNT / MG_CENTER_PASSWORD 登录 MG Center，并按 BINDING_DATA_AUTH_HEADER 加请求头。
BINDING_DATA_LOGIN=none
MG_CENTER_BASE_URL=https://mg-cli.meimeifa.com
MG_CENTER_ACCOUNT=
MG_CENTER_PASSWORD=
MG_LOGIN_TOKEN_FIELD=token
# 可选值：authorization-bearer / mmf-token / token / none
BINDING_DATA_AUTH_HEADER=authorization-bearer

# JSON 提取配置：直接统计列表，或读取已汇总字段。
BINDING_LIST_PATH=data.list
BINDING_STATUS_FIELD=status
BINDING_VALID_STATUS_VALUES=1
BINDING_PHONE_FIELD=phone,mobile,handset,tel
BINDING_DATE_FIELD=created_at
PARTNER_NAME_FIELD=retail_store_name
PARTNER_ID_FIELD=retail_store_id
TOP_PARTNER_LIMIT=20
BINDING_PAGINATE=true
BINDING_PAGE_SIZE=100
# TOTAL_BINDINGS_PATH=data.total
# PHONE_OBTAINED_PATH=data.withPhone
# PHONE_MISSING_PATH=data.withoutPhone

# 推送字段展示名，可以按后续口径调整。
REPORT_TITLE=恒奕美源绑定数据播报
REPORT_FIELDS=totalBindings:总绑定数,phoneObtained:已获手机号,phoneMissing:未获取手机号

# 私域宝推送配置。真实值只放本地 .env，不提交。
MG_SALON_ACCOUNT=
MG_SALON_PASSWORD=
MG_SYB_HANDSET=
MG_SYB_ROBOT_ID=
MG_SYB_SENDER_IDS=
# 兼容单好友配置；如果 MG_SYB_SENDER_IDS 已配置，会优先使用 MG_SYB_SENDER_IDS。
# MG_SYB_SENDER_ID=
# 群推送时使用 MG_SYB_GROUP_ID，并留空 MG_SYB_SENDER_IDS / MG_SYB_SENDER_ID。
# MG_SYB_GROUP_ID=

# 是否在发送前刷新 salonLogin / salonSyb 本地缓存。
SYB_REFRESH_CACHE=true

# 拼团/绑定网页看板服务配置。部署到服务器并走 Nginx 反代时建议保持 127.0.0.1。
GROUPBUY_BOARD_HOST=127.0.0.1
GROUPBUY_BOARD_PORT=8787
BOARD_SESSION_TTL_HOURS=12
UPSTREAM_TIMEOUT_MS=25000
PUSH_UPSTREAM_TIMEOUT_MS=25000

# 拼团接口配置。GROUPBUY_SESSION_TOKEN 如果过期，用户页面只展示维护提示，避免展示旧缓存数据。
# 仅管理员本地排查时才建议临时打开 GROUPBUY_ALLOW_BROWSER_SESSION_UPDATE。
GROUPBUY_DATA_URL=https://api-sy-z1.meimeifa.com/salon/order/mall/groupbuy/get?page=1&page_size=100&begin_date=&end_date=&order_status=&order_by=order&salon_id=18695&query_type=1&query=&brand_id=1637
GROUPBUY_TOKEN=
GROUPBUY_SESSION_TOKEN=
GROUPBUY_AUTO_REFRESH=true
GROUPBUY_REFRESH_COMMAND=
GROUPBUY_REFRESH_TIMEOUT_MS=30000
GROUPBUY_ALLOW_BROWSER_SESSION_UPDATE=false
GROUPBUY_ORDER_STATUS_VALUES=,100
GROUPBUY_SUCCESS_ORDER_STATUS_VALUES=100
GROUPBUY_EFFECTIVE_ORDER_STATUS_VALUES=7,200
GROUPBUY_PAGE_SIZE=100
GROUPBUY_MAX_PAGE=100
GROUPBUY_AMOUNT_UNIT=cent
